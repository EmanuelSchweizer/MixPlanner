generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Track {
  id        Int      @id @default(autoincrement())
  title     String
  artist    String
  bpm       Int?
  key       String?      // Camelot System e.g. "8A"
  energy    Int?         // 1–5 scale, will be entered by the user
  coverUrl  String?
  createdAt DateTime @default(now())
  setTracks SetTrack[]
}

model Set {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  setTracks SetTrack[]
}

model SetTrack {
  id      Int   @id @default(autoincrement())
  setId   Int
  trackId Int
  order   Int   // Order of the track in the set

  set   Set   @relation(fields: [setId], references: [id])
  track Track @relation(fields: [trackId], references: [id])

  @@unique([setId, trackId]) // one track can only be added once to a set
}